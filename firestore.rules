rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Validations
    function isValidUserConfig(data) {
      return data.keys().hasAll(['displayName', 'stars', 'gems'])
          && data.displayName is string && data.displayName.size() <= 100
          && data.stars is number && data.stars >= 0
          && data.gems is number && data.gems >= 0;
    }

    // Rules for Users
    match /users/{userId} {
      // Anyone signed in can read this (for Parent Stats table), 
      // but write is strictly owner only.
      allow read: if isSignedIn();
      
      allow create: if isOwner(userId) 
                    && isValidUserConfig(request.resource.data);
                    
      allow update: if isOwner(userId) 
                    && isValidUserConfig(request.resource.data);
                    
      allow delete: if isOwner(userId);
    }
  }
}
