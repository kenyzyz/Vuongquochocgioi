{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User learning statistics and game progress.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "selectedChar": { "type": "string" },
        "selectedPet": { "type": "string" },
        "selectedClass": { "type": "string" },
        "difficultyMode": { "type": "string" },
        "stars": { "type": "number" },
        "gems": { "type": "number" },
        "tickets": { "type": "number" },
        "level": { "type": "number" },
        "xp": { "type": "number" },
        "streakDays": { "type": "number" },
        "completedLessons": { "type": "number" },
        "totalQuestionsAnswered": { "type": "number" },
        "totalCorrectAnswers": { "type": "number" },
        "totalLearningTime": { "type": "number" },
        "missions": { "type": "object" },
        "rewardsHistory": { "type": "array" },
        "subjectStats": { "type": "object" },
        "updatedAt": { "type": "object", "description": "Server timestamp" }
      },
      "required": ["displayName", "stars", "gems", "tickets", "level", "xp"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    }
  }
}
